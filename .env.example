# Obrigatório
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo padrão para todos os agentes (opcional — default: gemini-2.5-flash)
# Exemplos: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Override por agente (opcional — sobrescreve GEMINI_MODEL para aquele agente)
# Útil para usar um modelo mais capaz no supervisor e um mais rápido nos demais
# GEMINI_MODEL_SUPERVISOR=gemini-2.5-pro
# GEMINI_MODEL_NMAP=gemini-2.5-flash
# GEMINI_MODEL_HEADERS=gemini-2.5-flash
# GEMINI_MODEL_GOBUSTER=gemini-2.5-flash
# GEMINI_MODEL_NIKTO=gemini-2.5-flash
# GEMINI_MODEL_NUCLEI=gemini-2.5-flash
# GEMINI_MODEL_WHATWEB=gemini-2.5-flash
# GEMINI_MODEL_SUBFINDER=gemini-2.5-flash
# GEMINI_MODEL_HISTORICO=gemini-2.5-flash
